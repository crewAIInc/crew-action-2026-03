# ProjectMind AI - Variáveis de ambiente
# Copie para .env e preencha os valores

# App
APP_NAME=ProjectMind AI
DEBUG=false
ENVIRONMENT=development

# Supabase (obrigatório para persistir projetos/dados)
# No dashboard: Settings > API — use Project URL e as duas chaves.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJ...sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua-service-role-key
# Opcional: se usar só uma chave no .env, defina como SUPABASE_KEY (ou SERVICE_ROLE_KEY para admin)
        

# Anthropic (ingestão/parsing; fallback LLM)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# CrewAI — OpenRouter (chave em https://openrouter.ai/keys)
CREWAI_API_KEY=
CREWAI_MODEL=openrouter/google/gemini-2.0-flash
CREWAI_PROJECT_ID=

# Telemetria (opcional; igual ao verificacao)
OTEL_SDK_DISABLED=true
CREWAI_DISABLE_TELEMETRY=true

# OpenAI (embeddings pgvector 1536; OpenRouter pode usar esta chave em alguns setups)
OPENAI_API_KEY=sk-...

# Redis (fila assíncrona)
REDIS_URL=redis://localhost:6379/0

# Integrações MCP (opcional)
ASANA_ACCESS_TOKEN=
SLACK_BOT_TOKEN=

# CORS (origens permitidas, separadas por vírgula; 5173 = Vite/Projectmanagementtool)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
